# NoorAI backend configuration — copy to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored).

# ── AI provider (OpenAI is primary) ──────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional fallback if OPENAI_API_KEY is unset.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Preferred provider: openai | gemini | auto (default). Admins can also switch
# at runtime via POST /api/admin/llm-provider.
LLM_PROVIDER=openai

# Set to 1 to bypass all LLMs and use the regex fallback (offline demo).
NOORAI_OFFLINE_MODE=0

# ── Persistence ───────────────────────────────────────────────────────────────
# firestore | json | (unset = auto: Firestore on Cloud Run / with a GCP project,
# otherwise JSON files for local dev).
NOORAI_STORE=
GOOGLE_CLOUD_PROJECT=

# Cloud Storage bucket for voice notes (required in production for durability).
NOORAI_VOICE_BUCKET=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Shared secret protecting /api/admin/* endpoints. Use a long random value.
ADMIN_TOKEN=
