# NoorAI backend configuration — copy to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored).

# ── Supabase (the only two values you must set) ───────────────────────────────
# From your Supabase project → Settings → API.
#   SUPABASE_URL : https://<your-project-ref>.supabase.co
#   SUPABASE_KEY : the service_role key (NOT the anon key — the backend needs
#                  full access; the key stays server-side only).
SUPABASE_URL=https://oiwoqlhcxrjimhujhrkm.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9pd29xbGhjeHJqaW1odWpocmttIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk0MzgwNzksImV4cCI6MjA5NTAxNDA3OX0.A1Vgx9QJEp9pkGxvNbjFzuesDr2tuevWCJI2lsOLkVg

# ── AI provider ───────────────────────────────────────────────────────────────
# OpenAI is the default. gpt-4o-mini is cheap and plenty for the agent pipeline.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional free fallback (Google AI Studio): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Preferred provider: openai | gemini | auto (default). Admins can also switch
# at runtime via POST /api/admin/llm-provider.
LLM_PROVIDER=openai

# Set to 1 to bypass all LLMs and use the regex fallback (offline demo).
NOORAI_OFFLINE_MODE=0

# ── Admin ─────────────────────────────────────────────────────────────────────
# Shared secret protecting /api/admin/* endpoints. Use a long random value.
ADMIN_TOKEN=
