# ─────────────────────────────────────────────────────────────
# NoorAI — repo-wide ignores
# ─────────────────────────────────────────────────────────────

# ── Secrets & local config (NEVER commit these) ──
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
# live session tokens
backend/data/tokens.json
# runtime agent debug logs (regenerated at startup)
backend/data/traces.json

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Flutter / Dart ──
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/build/
mobile/.pub-cache/
mobile/.pub/
mobile/coverage/
**/doc/api/
*.lock.bak
app.*.symbols
app.*.map.json

# ── Android build artifacts ──
mobile/android/.gradle/
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/
mobile/android/local.properties
mobile/android/key.properties
*.keystore
*.jks

# ── IDE / editor ──
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/settings.json
*.swp
*.swo

# ── OS noise ──
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs & temp ──
*.log
*.tmp
*.bak
